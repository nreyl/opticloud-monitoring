  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="OptiCloud Sprint 3 - Load Tests" enabled="true">
      <stringProp name="TestPlan.comments">ASR-1: 12000 concurrent users | ASR-2: latency &lt;= 100ms at 5000 users</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
